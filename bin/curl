#!/usr/bin/env bash

CURL=/usr/bin/curl

ARGS=("$@")
if [[ " $* " != *' --retry '* ]]; then
	ARGS=("--retry" "20" "${ARGS[@]}")
fi
if [[ " $* " != *' --retry-delay '* ]]; then
	ARGS=("--retry-delay" "1" "${ARGS[@]}")
fi
if [[ " $* " != *' --max-time '* ]] && [[ " $* " != *' -m '* ]]; then
	ARGS=("--max-time" "30" "${ARGS[@]}")
fi
if [[ " $* " != *' --continue-at '* ]] && [[ " $* " != *' -C '* ]]; then
	ARGS=("--continue-at" "-" "${ARGS[@]}")
fi

declare -i RET=0

x() {
	echo "+ $*" >&2
	"$@"
	RET=$?
}

while true; do
	x "$CURL" "${ARGS[@]}"
	echo "[curl] exit code: $RET" >&2
	if [[ $RET -eq 35 || $RET -eq 56 ]]; then
		# 35 - SSL connect error. The SSL handshaking failed.
		# 56 - Failure with receiving network data.
		continue
	fi

	exit $RET
done

exit 0
